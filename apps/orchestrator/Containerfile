# Stage 1: Build
FROM node:22-alpine AS builder
WORKDIR /app

# Copy root workspace files
COPY package.json package-lock.json* turbo.json tsconfig.base.json ./

# Copy all workspace package.json files
COPY apps/orchestrator/package.json apps/orchestrator/
COPY packages/shared/package.json packages/shared/
COPY packages/ticket-providers/package.json packages/ticket-providers/
COPY packages/claude-md-generator/package.json packages/claude-md-generator/

# Install dependencies
RUN npm install

# Copy source code
COPY packages/shared/ packages/shared/
COPY packages/ticket-providers/ packages/ticket-providers/
COPY packages/claude-md-generator/ packages/claude-md-generator/
COPY apps/orchestrator/ apps/orchestrator/

# Build everything
RUN npx turbo build --filter=@code-farm/orchestrator...

# Stage 2: Run
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOST=0.0.0.0

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy standalone output
COPY --from=builder /app/apps/orchestrator/.next/standalone ./
COPY --from=builder /app/apps/orchestrator/.next/static ./apps/orchestrator/.next/static
COPY --from=builder /app/apps/orchestrator/public ./apps/orchestrator/public 2>/dev/null || true

USER nextjs

EXPOSE 3000

CMD ["node", "apps/orchestrator/server.js"]
