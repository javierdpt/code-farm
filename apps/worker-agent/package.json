{
  "name": "@code-farm/worker-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "worker-agent": "dist/index.js"
  },
  "scripts": {
    "postinstall": "chmod +x ../../node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@code-farm/shared": "*",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
